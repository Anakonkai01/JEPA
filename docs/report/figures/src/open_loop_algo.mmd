flowchart TB
  START(["frame t in VAL session"]):::start --> FETCH

  FETCH["<b>Fetch inputs</b><br/>z_t ← pre-encoded latent of frame t<br/>z_goal ← pre-encoded latent of frame t+d &nbsp;⟵&nbsp; goal ~0.9 s ahead<br/>s_t ← state 12-D at t"]:::data --> GRID

  GRID(["for (steer, throttle) in 15×9 grid — 135 combinations"]):::loop --> ROLL

  ROLL["<b>Roll d steps</b><br/>AC Predictor + bicycle model<br/>→ predicted latent <b>ẑ</b>"]:::compute --> ENERGY

  ENERGY["E[steer, throttle] = mean L1(<b>ẑ</b>, z_goal)"]:::compute --> CHECK

  CHECK{"more\ncombinations?"}:::decision
  CHECK -- yes --> ROLL
  CHECK -- no --> ARGMIN

  ARGMIN["<b>(steer*, throttle*)</b> = argmin E<br/>model picks <b>both axes simultaneously</b>"]:::result --> RECORD

  RECORD["<b>Record</b><br/>sign(steer*) == sign(human_steer)?<br/>throttle* > 0?"]:::result --> NEXTFRAME

  NEXTFRAME(["next frame t"]):::start --> FETCH

