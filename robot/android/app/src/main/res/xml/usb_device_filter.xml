<?xml version="1.0" encoding="utf-8"?>
<!-- VID phổ biến cho ESP32 / USB-UART. ESP32-S3 native USB CDC = 0x303A (12346).
     Thêm CP210x/CH340/FTDI phòng board dùng cầu UART. (decimal vì attr là integer) -->
<resources>
    <usb-device vendor-id="12346" />   <!-- 0x303A Espressif (ESP32-S3 native USB) -->
    <usb-device vendor-id="4292" />    <!-- 0x10C4 Silicon Labs CP210x -->
    <usb-device vendor-id="6790" />    <!-- 0x1A86 QinHeng CH340 -->
    <usb-device vendor-id="1027" />    <!-- 0x0403 FTDI -->
</resources>
